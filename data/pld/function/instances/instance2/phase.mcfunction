#随机核心
loot spawn 1096 10 905 loot pld:instance2/pos
execute if entity @e[type=item,nbt={Item:{id:"minecraft:stone",components:{"minecraft:custom_data":{instance:2,pos:1}}}}] run function pld:instances/instance2/core/pos1
execute if entity @e[type=item,nbt={Item:{id:"minecraft:stone",components:{"minecraft:custom_data":{instance:2,pos:2}}}}] run function pld:instances/instance2/core/pos2
execute if entity @e[type=item,nbt={Item:{id:"minecraft:stone",components:{"minecraft:custom_data":{instance:2,pos:3}}}}] run function pld:instances/instance2/core/pos3
execute if entity @e[type=item,nbt={Item:{id:"minecraft:stone",components:{"minecraft:custom_data":{instance:2,pos:4}}}}] run function pld:instances/instance2/core/pos4
kill @e[type=item,nbt={Item:{id:"minecraft:stone",components:{"minecraft:custom_data":{instance:2}}}}]
bossbar set pl:instance2_core visible true

#火焰魔王的宠物-第二核心
loot spawn 1096 10 907 loot pld:instance2/pos2
execute if entity @e[type=item,nbt={Item:{id:"minecraft:redstone",components:{"minecraft:custom_data":{instance:2,pos:1}}}}] run function pld:instances/instance2/core2/pos1
execute if entity @e[type=item,nbt={Item:{id:"minecraft:redstone",components:{"minecraft:custom_data":{instance:2,pos:2}}}}] run function pld:instances/instance2/core2/pos2
execute if entity @e[type=item,nbt={Item:{id:"minecraft:redstone",components:{"minecraft:custom_data":{instance:2,pos:3}}}}] run function pld:instances/instance2/core2/pos3
kill @e[type=item,nbt={Item:{id:"minecraft:redstone",components:{"minecraft:custom_data":{instance:2}}}}]
bossbar set pl:instance2_core2 visible true

scoreboard players set #system instance2_body 0 

#重置灼焰效果
scoreboard players set #system instance2_firelv 0

#设置时间
scoreboard players set #system instance2_tick 3600
#灼焰技能释放
schedule function pld:instances/instance2/damage/delay 5s