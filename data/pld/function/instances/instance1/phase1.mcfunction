#检查失敗次数是否达到上限
execute if score #system instance1_failed matches 8.. run function pld:instances/instance1/instance1_failed

#裂棺阶段一：
scoreboard players set #system instance1_phase 1
scoreboard players set #system instance1_fail1 0
scoreboard players set #system instance1_fail2 0

#选定庇护颜色
loot spawn 2822 84 -414 mine 2805 76 -414
execute if entity @e[type=item,nbt={Item:{id:"minecraft:white_wool",components:{"minecraft:custom_data":{instance:1}}}}] run scoreboard players set #system instance1_color 1
execute if entity @e[type=item,nbt={Item:{id:"minecraft:red_wool",components:{"minecraft:custom_data":{instance:1}}}}] run scoreboard players set #system instance1_color 2
execute if entity @e[type=item,nbt={Item:{id:"minecraft:lime_wool",components:{"minecraft:custom_data":{instance:1}}}}] run scoreboard players set #system instance1_color 3
kill @e[type=item,nbt={Item:{components:{"minecraft:custom_data":{instance:1}}}}]
#羊毛替换
execute if score #system instance1_color matches 1 run setblock 2805 75 -405 minecraft:white_wool replace
execute if score #system instance1_color matches 1 run setblock 2805 76 -414 minecraft:white_wool replace
execute if score #system instance1_color matches 1 run setblock 2805 75 -423 minecraft:white_wool replace
#羊毛替换
execute if score #system instance1_color matches 2 run setblock 2805 75 -405 minecraft:red_wool replace
execute if score #system instance1_color matches 2 run setblock 2805 76 -414 minecraft:red_wool replace
execute if score #system instance1_color matches 2 run setblock 2805 75 -423 minecraft:red_wool replace
#羊毛替换
execute if score #system instance1_color matches 3 run setblock 2805 75 -405 minecraft:lime_wool replace
execute if score #system instance1_color matches 3 run setblock 2805 76 -414 minecraft:lime_wool replace
execute if score #system instance1_color matches 3 run setblock 2805 75 -423 minecraft:lime_wool replace
